        },
        "C435": {
          "stepper_x": { "position_endstop": 457, "position_min": -10, "position_max": 457 },
          "stepper_y": { "position_endstop": -33, "position_min": -33, "position_max": 435 },
          "stepper_z": { "position_max": 400 },
          "resonance_tester": { "probe_points": "215,215,20" },
          "bed_mesh": { "mesh_min": "10,10", "mesh_max": "420,420", "probe_count": "10,10", "zero_reference_position": "200,200" },
          "screws_tilt_adjust": { "screws": [
            { "x": 49.5, "y": 371.5, "name": "front left screw" },
            { "x": 420, "y": 371.5, "name": "front right screw" },
