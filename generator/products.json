    "HYPERDRIVE_3P2L": {
      "parent": "SMARTPAD",
      "description": "Smartbox HyperDrive 3PRO+2LITE. UART=E2-E6, USB=E7-E11",
      "children": ["YMS_PRO", "YMS_LITE"],
      "detection": {
        "uart": { "serial": "/dev/ttyS2", "slots": "E2-E6" },
        "usb": { "serial": "/dev/serial/by-id/usb-1a86_USB_Serial-if00-port0", "slots": "E7-E11" }
      },
      "slots": {
        "E2": ["YMS_PRO", "YMS_LITE"],
        "E3": ["YMS_PRO", "YMS_LITE"],
        "E4": ["YMS_PRO", "YMS_LITE"],
        "E5": ["YMS_LITE"],
        "E6": ["YMS_LITE"]
      },
      "cfg": {
        "mcu_smartbox": { "restart_method": "command" },
        "controller_fan_smartbox": {
          "pin": "smartbox:PB8", "fan_speed": 1.0, "idle_timeout": 10, "idle_speed": 0,
          "kick_start_time": 0.01, "off_below": 0.1
        },
        "dryer": {
          "name": "YMS-3-PRO",
          "heater_pin": "smartbox:PC8", "sensor_type": "100K4190YUMI", "sensor_pin": "smartbox:PC1",
          "max_power": 1, "control": "pid", "pid_kp": 50, "pid_ki": 50, "pid_kd": 50,
          "min_temp": -50, "max_temp": 110,
          "fan_pin": "smartbox:PC6", "fan_max_power": 1, "fan_off_below": 0.31, "fan_heater_temp": 25,
          "verify_max_error": 180000, "verify_check_gain_time": 3000, "verify_hysteresis": 10, "verify_heating_gain": 2
        }
      }
    },

