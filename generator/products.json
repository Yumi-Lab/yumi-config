        },
        "C335": {
          "stepper_x": { "position_endstop": 357, "position_min": -10, "position_max": 357 },
          "stepper_y": { "position_endstop": -33, "position_min": -33, "position_max": 335 },
          "stepper_z": { "position_max": 340 },
          "resonance_tester": { "probe_points": "165,165,20" },
          "bed_mesh": { "mesh_min": "10,10", "mesh_max": "320,320", "probe_count": "10,10", "zero_reference_position": "150,150" },
          "screws_tilt_adjust": { "screws": [
            { "x": 49.5, "y": 271.5, "name": "front left screw" },
            { "x": 320, "y": 271.5, "name": "front right screw" },
            { "x": 320, "y": 1, "name": "rear right screw" },
            { "x": 49.5, "y": 1, "name": "rear left screw" }
