{
  "components": {

    "SMARTPAD": {
      "parent": null,
      "description": "SmartPad — SBC NanoPi/RPi, racine de tout le système",
      "children": ["C_SERIES_3D_PRINTER", "HYPERDRIVE_3P2L"],
      "cfg": {
        "mcu_rpi": { "serial": "/tmp/klipper_host_mcu" },
        "adxl345": { "cs_pin": "rpi:gpio13", "spi_bus": "spidev1.0" },
        "temperature_sensor_host": { "sensor_type": "temperature_host", "min_temp": 0, "max_temp": 100 }
      }
    },

    "C_SERIES_3D_PRINTER": {
      "parent": "SMARTPAD",
      "description": "Imprimante C Series — carte mère avec 2 slots extrudeur (E0, E1) + mécanique XYZ",
      "children": ["YMS_LITE", "CHROMA_X12_HOTEND", "DIRECT_DRIVE_HOTEND"],
      "slots": {
        "E0": { "accepts": ["YMS_LITE", "DIRECT_DRIVE_HOTEND"], "exclusive": true, "comment": "E0 = soit un YMS soit le direct drive (mutuellement exclusif)" },
        "E1": { "accepts": ["YMS_LITE"] }
      },
      "cfg": {
        "mcu": { "serial": "/dev/ttyS1", "restart_method": "command" },
        "printer": {
          "kinematics": "cartesian",
          "max_velocity": 700, "max_accel": 20000,
          "max_z_velocity": 25, "max_z_accel": 1000
        },
        "idle_timeout": { "timeout": 99999999 },
        "virtual_sdcard": { "path": "~/printer_data/gcodes/" },
        "save_variables": { "filename": "~/printer_data/config/variables.cfg" },
        "exclude_object": {},
        "gcode_arcs": { "resolution": 0.1 },
        "includes": ["plr.cfg", "timelapse.cfg", "moonraker_obico_macros.cfg"],
        "stepper_x": {
          "step_pin": "PB1", "dir_pin": "PB0", "enable_pin": "!PA15",
          "microsteps": 16, "rotation_distance": 40,
          "endstop_pin": "tmc2209_stepper_x:virtual_endstop",
          "homing_speed": 70, "homing_retract_dist": 0
        },
        "tmc2209_stepper_x": {
          "uart_pin": "PB15", "run_current": 1.2, "hold_current": 1.1,
          "stealthchop_threshold": 0, "driver_sgthrs": 150, "diag_pin": "PA13"
        },
        "stepper_y": {
          "step_pin": "PA1", "dir_pin": "!PA0", "enable_pin": "!PC5",
          "microsteps": 16, "rotation_distance": 40,
          "endstop_pin": "tmc2209_stepper_y:virtual_endstop",
          "homing_speed": 50, "homing_retract_dist": 0
        },
        "tmc2209_stepper_y": {
          "uart_pin": "PC11", "run_current": 1.2, "hold_current": 1.2,
          "stealthchop_threshold": 0, "driver_sgthrs": 100, "diag_pin": "PB9"
        },
        "stepper_z": {
          "step_pin": "PC3", "dir_pin": "PC2", "enable_pin": "!PC4",
          "microsteps": 16, "rotation_distance": 8,
          "endstop_pin": "probe:z_virtual_endstop",
          "position_min": -5, "homing_speed": 5, "second_homing_speed": 5, "homing_retract_dist": 5
        },
        "tmc2209_stepper_z": {
          "uart_pin": "PC10", "run_current": 1.2, "hold_current": 1.2, "stealthchop_threshold": 0
        },
        "heater_bed": {
          "heater_pin": "PC9", "sensor_type": "EPCOS 100K B57560G104F", "sensor_pin": "PC0",
          "control": "pid", "pid_kp": 66.717, "pid_ki": 0.847, "pid_kd": 1313.487,
          "min_temp": 0, "max_temp": 130
        },
        "fan": { "pin": "PC7" },
        "controller_fan_motherboard": {
          "pin": "PB8", "fan_speed": 0.7, "idle_timeout": 10, "idle_speed": 0,
          "kick_start_time": 0.01, "off_below": 0.1
        },
        "fan_generic_aux": { "pin": "PA2" },
        "verify_heater_extruder": { "max_error": 500, "check_gain_time": 20, "hysteresis": 20, "heating_gain": 2 },
        "verify_heater_bed": { "max_error": 500, "hysteresis": 10 },
        "probe": {
          "pin": "PA14", "x_offset": -17, "y_offset": 30,
          "speed": 5, "samples": 6, "samples_result": "average",
          "sample_retract_dist": 2, "samples_tolerance": 0.08, "samples_tolerance_retries": 10
        },
        "probe_pressure": { "pin": "!PB7", "speed": 10.0, "lift_speed": 10 },
        "yumi_z_offset_calculator": {
          "compression_offset": -0.1, "approach_speed": 3.0, "retract_dist": 10.0,
          "max_probe_travel": 20.0, "max_probe_times": 10, "probe_delay": 1000,
          "z_hop": 5, "samples_tolerance": 0.01
        },
        "bed_mesh": { "speed": 120, "horizontal_move_z": 10, "algorithm": "bicubic", "adaptive_margin": 5 },
        "screws_tilt_adjust": { "horizontal_move_z": 10, "speed": 200, "screw_thread": "CCW-M3" },
        "homing_override": { "axes": "xyz", "x_type": "sensorless", "y_type": "sensorless", "z_type": "probe" },
        "tmc_autotune": {
          "voltage": 24,
          "stepper_x": { "motor": "BJ42D29-28V03", "tuning_goal": "auto", "toff": 3, "tbl": 2, "sg4_thrs": 50, "extra_hysteresis": 0, "pwm_freq_target": 25000 },
          "stepper_y": { "motor": "BJ42D29-28V03", "tuning_goal": "auto", "toff": 3, "tbl": 2, "sg4_thrs": 50, "extra_hysteresis": 0, "pwm_freq_target": 25000 },
          "stepper_z": { "motor": "BJ42D07-06V02", "tuning_goal": "auto", "toff": 3, "tbl": 2, "sg4_thrs": 50, "extra_hysteresis": 0, "pwm_freq_target": 25000 }
        }
      },
      "overrides_by_model": {
