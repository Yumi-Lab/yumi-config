          "stepper_x": { "position_endstop": 257, "position_min": -10, "position_max": 257 },
          "stepper_y": { "position_endstop": -33, "position_min": -33, "position_max": 239 },
          "stepper_z": { "position_max": 270 },
          "resonance_tester": { "probe_points": "115,115,20" },
          "bed_mesh": { "mesh_min": "10,10", "mesh_max": "223,225", "probe_count": "10,10", "zero_reference_position": "100.5,147.5" },
          "screws_tilt_adjust": { "screws": [
            { "x": 49.5, "y": 171.5, "name": "front left screw" },
